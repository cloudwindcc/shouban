# Google Gemini API Configuration
GEMINI_API_KEY=your_google_gemini_api_key_here

# Default Generation Prompt
DEFAULT_PROMPT=Use the nano-banana model to create a 1/7 scale commercialized figure of the character in the illustration, in a realistic style and environment. Place the figure on a computer desk, using a circular transparent acrylic base without any text. On the computer screen, display the ZBrush modeling process of the figure. Next to the computer screen, place a BANDAI-style toy packaging box printed with the original artwork.

# Server Configuration
PORT=3000
GEMINI_MODEL=nano-banana

# Cloudflare Pages Environment Variables
# Set these in Cloudflare Pages dashboard:
# - GEMINI_API_KEY
# - DEFAULT_PROMPT
# - GEMINI_MODEL
